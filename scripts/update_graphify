#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUT_DIR="$ROOT_DIR/graphify-out"
MAIN_GRAPH="$OUT_DIR/graph.json"
MERGED_GRAPH="$OUT_DIR/merged-graph.json"
TMP_MERGED="$OUT_DIR/.merged-graph.tmp.json"
SPLIT_MERGE_SCRIPT="$ROOT_DIR/scripts/graphify_split_merge.py"
GRAPHIFY_BIN="$(command -v graphify)"
PYTHON_BIN="${PYTHON_BIN:-}"

cd "$ROOT_DIR"

if [[ -z "$GRAPHIFY_BIN" ]]; then
  echo "Error: graphify command not found in PATH." >&2
  exit 1
fi

if [[ ! -f "$SPLIT_MERGE_SCRIPT" ]]; then
  echo "Error: expected split/merge pass script at $SPLIT_MERGE_SCRIPT." >&2
  exit 1
fi

if [[ -z "$PYTHON_BIN" ]]; then
  SHEBANG="$(head -n 1 "$GRAPHIFY_BIN" 2>/dev/null || true)"
  if [[ "$SHEBANG" == '#!'* ]]; then
    CANDIDATE="${SHEBANG#\#!}"
    CANDIDATE="${CANDIDATE%% *}"
    if [[ -x "$CANDIDATE" ]]; then
      PYTHON_BIN="$CANDIDATE"
    fi
  fi
fi

if [[ -z "$PYTHON_BIN" ]]; then
  PYTHON_BIN="python3"
fi

if ! command -v "$PYTHON_BIN" >/dev/null 2>&1 && [[ ! -x "$PYTHON_BIN" ]]; then
  echo "Error: python runtime not found: $PYTHON_BIN" >&2
  exit 1
fi

echo "[update_graphify] Pass 1/3: static AST/code graph update"
graphify update .

if [[ ! -f "$MAIN_GRAPH" ]]; then
  echo "Error: expected main graph at $MAIN_GRAPH after static update." >&2
  exit 1
fi

echo "[update_graphify] Pass 2/3: dependency/relationship scope build + merged graph"
"$PYTHON_BIN" "$SPLIT_MERGE_SCRIPT"

if [[ ! -f "$MERGED_GRAPH" ]]; then
  echo "Error: expected merged graph at $MERGED_GRAPH after split/merge pass." >&2
  exit 1
fi

echo "[update_graphify] Pass 3/3: semantic pending check + community analysis"
if ! graphify check-update .; then
  echo "[update_graphify] Warning: semantic pending check command failed; continuing with clustering." >&2
fi

if [[ -f "$OUT_DIR/needs_update" ]]; then
  echo "[update_graphify] Semantic/doc changes are pending. Run '/graphify --update' in your AI assistant to refresh non-code semantics."
fi

graphify cluster-only .

mkdir -p "$OUT_DIR"

# Preserve legacy behavior: keep incrementally merged-graph history by merging the
# freshly updated main graph into the existing merged graph snapshot.
if [[ -f "$MERGED_GRAPH" ]]; then
  echo "[update_graphify] Reconciling merged graph with freshly updated main graph..."
  graphify merge-graphs "$MERGED_GRAPH" "$MAIN_GRAPH" --out "$TMP_MERGED"
  mv "$TMP_MERGED" "$MERGED_GRAPH"
else
  echo "[update_graphify] No merged graph found; creating one from main graph..."
  cp "$MAIN_GRAPH" "$MERGED_GRAPH"
fi

echo "[update_graphify] Done."
echo "  main:   $MAIN_GRAPH"
echo "  merged: $MERGED_GRAPH"
