#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUT_DIR="$ROOT_DIR/graphify-out"
MAIN_GRAPH="$OUT_DIR/graph.json"
MERGED_GRAPH="$OUT_DIR/merged-graph.json"
TMP_MERGED="$OUT_DIR/.merged-graph.tmp.json"
SPLIT_MERGE_SCRIPT="$ROOT_DIR/scripts/graphify_split_merge.py"
SEMANTIC_REFRESH_SCRIPT="$ROOT_DIR/scripts/graphify_semantic_refresh.py"
GRAPHIFY_BIN="$(command -v graphify || true)"
PYTHON_BIN="${PYTHON_BIN:-}"
SEMANTIC_NEEDED=0

cd "$ROOT_DIR"

if [[ -z "$GRAPHIFY_BIN" ]]; then
  # Try active virtual env if present
  if [[ -x "$ROOT_DIR/.venv/bin/graphify" ]]; then
    GRAPHIFY_BIN="$ROOT_DIR/.venv/bin/graphify"
    echo "[update_graphify] Resolved graphify from active .venv: $GRAPHIFY_BIN"
  fi
fi

if [[ -z "$GRAPHIFY_BIN" ]]; then
  # Try reading from .graphify_python if it exists
  if [[ -f "$OUT_DIR/.graphify_python" ]]; then
    CANDIDATE_PY="$(cat "$OUT_DIR/.graphify_python" | tr -d '\r\n')"
    if [[ -x "$CANDIDATE_PY" ]]; then
      CANDIDATE_DIR="$(dirname "$CANDIDATE_PY")"
      if [[ -x "$CANDIDATE_DIR/graphify" ]]; then
        GRAPHIFY_BIN="$CANDIDATE_DIR/graphify"
        echo "[update_graphify] Resolved graphify from .graphify_python: $GRAPHIFY_BIN"
      fi
    fi
  fi
fi

if [[ -z "$GRAPHIFY_BIN" ]]; then
  # Try to find in registered conda environments
  if command -v conda >/dev/null 2>&1; then
    while read -r env_path; do
      if [[ -d "$env_path/bin" ]] && [[ -x "$env_path/bin/graphify" ]]; then
        GRAPHIFY_BIN="$env_path/bin/graphify"
        echo "[update_graphify] Resolved graphify from conda environment: $GRAPHIFY_BIN"
        break
      fi
    done < <(conda env list 2>/dev/null | grep -v '^#' | awk '{print $NF}' | grep -v '^$')
  fi
fi

if [[ -z "$GRAPHIFY_BIN" ]]; then
  echo "Error: graphify command not found." >&2
  exit 1
fi

echo "[update_graphify] Using graphify binary: $GRAPHIFY_BIN"

if [[ -z "$PYTHON_BIN" ]]; then
  CANDIDATE_DIR="$(dirname "$GRAPHIFY_BIN")"
  if [[ -x "$CANDIDATE_DIR/python" ]]; then
    PYTHON_BIN="$CANDIDATE_DIR/python"
    echo "[update_graphify] Resolved python relative to graphify: $PYTHON_BIN"
  elif [[ -x "$CANDIDATE_DIR/python3" ]]; then
    PYTHON_BIN="$CANDIDATE_DIR/python3"
    echo "[update_graphify] Resolved python3 relative to graphify: $PYTHON_BIN"
  fi
fi

if [[ -z "$PYTHON_BIN" ]]; then
  SHEBANG="$(head -n 1 "$GRAPHIFY_BIN" 2>/dev/null || true)"
  if [[ "$SHEBANG" == '#!'* ]]; then
    CANDIDATE="${SHEBANG#\#!}"
    CANDIDATE="${CANDIDATE%% *}"
    if [[ -x "$CANDIDATE" ]] && "$CANDIDATE" --version 2>&1 | grep -q "Python"; then
      PYTHON_BIN="$CANDIDATE"
      echo "[update_graphify] Resolved python from shebang: $PYTHON_BIN"
    fi
  fi
fi

if [[ -z "$PYTHON_BIN" ]]; then
  PYTHON_BIN="python3"
  echo "[update_graphify] Defaulting to system python3: $PYTHON_BIN"
fi

if ! command -v "$PYTHON_BIN" >/dev/null 2>&1 && [[ ! -x "$PYTHON_BIN" ]]; then
  echo "Error: python runtime not found: $PYTHON_BIN" >&2
  exit 1
fi

echo "[update_graphify] Using python binary: $PYTHON_BIN"

echo "[update_graphify] Checking if semantic refresh is needed..."
if "$PYTHON_BIN" "$SEMANTIC_REFRESH_SCRIPT" --check-needed .; then
  SEMANTIC_NEEDED=0
  echo "[update_graphify] Semantic refresh is NOT needed."
else
  STATUS=$?
  if [[ "$STATUS" -eq 10 ]]; then
    SEMANTIC_NEEDED=1
    echo "[update_graphify] Semantic refresh IS needed."
  else
    echo "Error: failed to determine whether semantic refresh is needed." >&2
    exit "$STATUS"
  fi
fi

echo "[update_graphify] Pass 1/3: static AST/code graph update"
"$GRAPHIFY_BIN" update .

if [[ ! -f "$MAIN_GRAPH" ]]; then
  echo "Error: expected main graph at $MAIN_GRAPH after static update." >&2
  exit 1
fi

echo "[update_graphify] Pass 2/3: dependency/relationship scope build + merged graph"
"$PYTHON_BIN" "$SPLIT_MERGE_SCRIPT"

if [[ ! -f "$MERGED_GRAPH" ]]; then
  echo "Error: expected merged graph at $MERGED_GRAPH after split/merge pass." >&2
  exit 1
fi

echo "[update_graphify] Pass 3/3: semantic refresh + community analysis"
if [[ "$SEMANTIC_NEEDED" -eq 1 ]]; then
  echo "[update_graphify] Semantic/doc changes detected; refreshing semantic graph data."
  "$PYTHON_BIN" "$SEMANTIC_REFRESH_SCRIPT" .
else
  echo "[update_graphify] No semantic/doc refresh needed."
  "$GRAPHIFY_BIN" cluster-only .
fi

mkdir -p "$OUT_DIR"

# Preserve legacy behavior: keep incrementally merged-graph history by merging the
# freshly updated main graph into the existing merged graph snapshot.
if [[ -f "$MERGED_GRAPH" ]]; then
  echo "[update_graphify] Reconciling merged graph with freshly updated main graph..."
  "$GRAPHIFY_BIN" merge-graphs "$MERGED_GRAPH" "$MAIN_GRAPH" --out "$TMP_MERGED"
  mv "$TMP_MERGED" "$MERGED_GRAPH"
  "$PYTHON_BIN" "$SPLIT_MERGE_SCRIPT" --refresh-merged-views
else
  echo "[update_graphify] No merged graph found; creating one from main graph..."
  cp "$MAIN_GRAPH" "$MERGED_GRAPH"
  "$PYTHON_BIN" "$SPLIT_MERGE_SCRIPT" --refresh-merged-views
fi

echo "[update_graphify] Done."
echo "  main:   $MAIN_GRAPH"
echo "  merged: $MERGED_GRAPH"
