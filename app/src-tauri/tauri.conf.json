{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI YouTube Shorts Generator",
  "version": "0.1.0",
  "identifier": "com.aiyoutubeshorts.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "AI YouTube Shorts Generator",
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'none'; object-src 'none'; frame-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; media-src 'self' asset: http://asset.localhost data: blob:; worker-src 'none'; form-action 'none'",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3MTczQTBFMTBCOUQ0RDkKUldUWjFMa1FEam9YdC9jblZCRHlWb25XSXptL3hBSU53TWZhRW9WaEdvdENhZTRGalUvNG80YVMK",
      "endpoints": [
        "https://license-worker.demandscout.workers.dev/updates/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
