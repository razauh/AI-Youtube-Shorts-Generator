{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI YouTube Shorts Generator",
  "version": "0.1.0",
  "identifier": "com.aiyoutubeshorts.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "AI YouTube Shorts Generator",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
