{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI YouTube Shorts Admin",
  "version": "0.1.0",
  "identifier": "com.aiyoutubeshorts.admin",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173/admin.html"
  },
  "app": {
    "windows": [
      {
        "label": "admin",
        "title": "AI YouTube Shorts Admin",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* https://localhost:* tauri: asset:; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:",
      "capabilities": ["admin"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
